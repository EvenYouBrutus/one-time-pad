[package]
name = "otp-cipher"
version = "0.1.0"
edition = "2024"
description = "One-Time Pad encryption library"
license = "MIT"
readme = "README.md"
keywords = ["cryptography", "otp", "cipher"]
categories = ["cryptography"]

[lib]
path = "src/lib.rs"

[[bin]]
name = "otp"
path = "src/main.rs"

[dependencies]
rand = "0.8"